# =========================================================
#  Xray / Reality
# =========================================================
# Сгенерировать: xray x25519
XRAY_PRIVATE_KEY=REPLACE_ME
XRAY_PUBLIC_KEY=REPLACE_ME
# Маскирующий SNI — домен с TLS 1.3 + X25519 + H2 в том же регионе.
# Кандидаты: gateway.icloud.com, www.lovelive-anime.jp, dl.google.com
XRAY_SNI=gateway.icloud.com
XRAY_FINGERPRINT=chrome
# Короткие ID по умолчанию (для пустого юзера); на каждого юзера
# генерируется свой shortId в users.json.
XRAY_DEFAULT_SHORT_IDS=,0123456789abcdef

# =========================================================
#  Сервер
# =========================================================
SERVER_IP=0.0.0.0
SERVER_LABEL=xray-proxy
CDN_DOMAIN=proxy.example.com

# Локальный порт WebSocket (за Caddy/Nginx TLS terminator)
CDN_LOCAL_PORT=8080
CDN_WS_PATH=/stream

# =========================================================
#  Telegram-бот
# =========================================================
BOT_TOKEN=REPLACE_ME
# Список через запятую: 123456789,987654321
ADMIN_IDS=
# Секунды между проверками доступности (мониторинг)
CHECK_INTERVAL=300
# Сколько подряд фейлов прежде чем алертить
FAIL_THRESHOLD=3
# Минимум секунд между повторными алертами
ALERT_COOLDOWN=3600
MONITOR_ENABLED=1

# =========================================================
#  Vultr
# =========================================================
VULTR_API_KEY=REPLACE_ME
SERVER_REGION=waw
SERVER_PLAN=vc2-1c-1gb
SERVER_OS_ID=2284
# Публичный SSH-ключ для cloud-init (обязательно — root-пароль отключается)
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... user@host

# =========================================================
#  Cloudflare
# =========================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
DNS_RECORD_NAME=proxy.example.com

# =========================================================
#  Telegram уведомления менеджера (опционально)
# =========================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================================================
#  Файлы состояния (абсолютные пути)
# =========================================================
USERS_DB=/usr/local/etc/xray/users.json
XRAY_CONFIG=/usr/local/etc/xray/config.json
VULTR_STATE_FILE=/var/lib/xray-proxy/vultr_state.json
