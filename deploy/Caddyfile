# Caddy — TLS-терминатор для WebSocket-канала.
#
# Слушает :8443, потому что :443 занят Reality. Cloudflare ходит на этот порт
# через Origin Rule (Rules → Origin Rules → Override resolved port = 8443).
# Клиент по-прежнему ходит на CF на :443 (CDN_PUBLIC_PORT).
#
# Сертификат Let's Encrypt получает certbot через DNS-01 (Cloudflare API
# token), потому что HTTP-01 не работает (CF проксирует), а TLS-ALPN-01
# требует свободный :443 (его занимает Reality).
#
# Подставляются через envsubst при установке: $CDN_DOMAIN, $CDN_LOCAL_PORT.

{$CDN_DOMAIN}:8443 {
    tls /etc/letsencrypt/live/{$CDN_DOMAIN}/fullchain.pem /etc/letsencrypt/live/{$CDN_DOMAIN}/privkey.pem

    encode gzip

    @ws {
        path /stream
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @ws 127.0.0.1:{$CDN_LOCAL_PORT}

    # Всё остальное — 404, чтобы не светиться как прокси.
    respond 404
}
